// Firestore rules — deployed as part of Phase 1 (see
// docs/ai-workflow/PHASE1C_EXECUTION_RUNBOOK.md). Companion to
// docs/ai-workflow/PHASE1_IMPLEMENTATION_PLAN.md for the original rationale
// and verification checklist.
//
// Scope: ADR-002 Phase 1 (role stored as a Firestore field, immutable from clients)
// + ADR-001 Option A (sensitive fields split into a `private/sensitive` subdocument)
// + ADR-003 (Guest is simply absent from every allow-list — no special-casing needed).
//
// Role storage: `users/{uid}.type` (int). 0=Admin, 1=Customer, 2=Reception,
// 3=Maintenance, 9=Guest (reserved, intentionally granted nothing below).

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----

    function isSignedIn() {
      return request.auth != null;
    }

    // NOTE: this performs a document read on every rule evaluation that calls it.
    // See PHASE1_IMPLEMENTATION_PLAN.md's cost note — this is the expected,
    // accepted cost of Phase 1's field-based role model (Phase 2 / ADR-002
    // removes this cost via Custom Claims).
    function callerType() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.type
        : null;
    }

    function isAdmin()       { return callerType() == 0; }
    function isCustomer()    { return callerType() == 1; }
    function isReception()   { return callerType() == 2; }
    function isMaintenance() { return callerType() == 3; }
    // Guest (9) and any unrecognized value: deliberately not given a helper.
    // Allow-list model — anything not explicitly named above gets nothing,
    // by construction, per ADR-003. Do not add isGuest()/grant it access
    // without a new ADR.

    function isStaff() {
      return isAdmin() || isReception() || isMaintenance();
    }

    // ---- users/{uid} ----

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isStaff());

      // New profile creation: only the user themselves, and only as Customer.
      // Matches the only code path that creates this document today
      // (AuthServices.completeUserProfile, called once at signup).
      //
      // The stored phoneNumber must equal the phone number Firebase Auth
      // verified via OTP for this token (request.auth.token.phone_number) —
      // not merely whatever the client chooses to send. This is required for
      // functions/index.js's linkDevicesToNewCustomer to be trustworthy: that
      // function reads the verified phone directly from the Auth user
      // record (not this field) precisely so its correctness never depends
      // on this rule, but this rule still closes a real spoofing gap
      // elsewhere — e.g. NewDeviceServices.getUserIdByPhoneNumber (staff
      // linking a device by querying this users/{uid}.phoneNumber field) —
      // without this check, a customer could register with someone else's
      // phone number and have that person's devices misattributed.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.type == 1
        && request.resource.data.phoneNumber == request.auth.token.phone_number;

      // Profile updates: only the user themselves, and `type` may never change.
      // This applies even to Admins editing their own document — Phase 1
      // intentionally has NO client-side path to change any role, including
      // one's own. Role changes are Admin-SDK/Console only in Phase 1.
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.type == resource.data.type;

      allow delete: if false; // no deletion flow exists today; revisit if one is built.

      // users/{uid}/meta/isActivated
      match /meta/{metaDoc} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isStaff());
        // Confirmed by product owner (2026-07-03): this is currently changed
        // manually via the Firebase Console by a privileged operator, which
        // uses IAM-authenticated access and is NOT subject to these rules —
        // this deny-all-client-writes rule does not affect that workflow.
        // A future Admin user-management feature (see ADR-004) will need a
        // trusted server-side mechanism (Cloud Function) to write this field
        // on behalf of an in-app Admin action — never a direct client write,
        // which would reopen the same class of risk ADR-002 closes for `type`.
        allow write: if false;
      }
    }

    // ---- maintenanceDevices/{deviceId} ----

    match /maintenanceDevices/{deviceId} {
      // Staff: full unfiltered read. Customer: only their own device, AND
      // the client query must be shaped to match (e.g. a `where('userId', '==', uid)`
      // filter) — Firestore rejects list queries it can't prove are scoped to
      // this condition. The existing customer code path already filters this
      // way (MaintenanceListServices.streamMaintenanceDevices), so no query
      // shape change is expected to be needed — verify per the checklist.
      allow read: if isSignedIn() && (
        isStaff() ||
        (isCustomer() && resource.data.userId == request.auth.uid)
      );

      // Create is staff-wide (Admin, Reception, Maintenance), per explicit
      // product-owner decision (2026-07-03). Customers and Guest are denied.
      allow create: if isSignedIn() && isStaff();

      // recordState lifecycle — see ADR-005 (2026-07-23). Three distinct
      // transitions, replacing what used to be one blanket staff-wide update
      // rule:
      //  - Archive: any staff member may move a record that isn't already
      //    archived into `archived`. Preserves the document, Storage images,
      //    and the private/sensitive subdocument untouched — reversible.
      //  - Restore: Admin-only, archived -> active. Enforced here, not just
      //    by an Admin-only screen — a route/UI gate alone is not a
      //    substitute for the write itself being denied.
      //  - Ordinary edits (device details, Fixed/Deliver transitions):
      //    staff-wide, exactly as before this split existed, but only while
      //    the record isn't archived — an archived record is frozen until
      //    an Admin restores it (ADR-005, "Freezing archived records": no
      //    metadata-correction exception in v1).
      // `.get('recordState', 'active')` treats any document written before
      // this field existed (no recordState at all) as implicitly active, so
      // this rule doesn't retroactively break every pre-migration document
      // the moment it deploys — see ADR-005 "Migration".
      allow update: if isSignedIn() && (
        (isStaff()
          && resource.data.get('recordState', 'active') != 'archived'
          && request.resource.data.recordState == 'archived') ||
        (isAdmin()
          && resource.data.get('recordState', 'active') == 'archived'
          && request.resource.data.recordState == 'active') ||
        (isStaff()
          && resource.data.get('recordState', 'active') != 'archived'
          && request.resource.data.get('recordState', 'active') != 'archived')
      );

      // Deletion cascades client-side today (Storage images + the
      // private/sensitive subdocument below must also be deleted by the
      // calling code — Firestore does not cascade-delete subcollections
      // automatically). Deliberately UNCHANGED here even though ADR-005
      // moves permanent deletion to a server-side-only Cloud Function
      // (`permanentlyDeleteDevice`) with its own Admin-only, archived-only
      // authorization — narrowing this to `if false` is sequenced into the
      // second PR of that rollout, together with the client cutover that
      // stops calling this path, so this rule and the shipped client action
      // it backs never fall out of sync mid-rollout. See ADR-005 "Rollout".
      allow delete: if isSignedIn() && isStaff();

      // Sensitive fields (pin, patternLock, notesHidden) — ADR-001 Option A.
      // No customer exception, ever, per explicit product-owner instruction:
      // the owning customer must never read these values.
      match /private/{doc} {
        allow read: if isSignedIn() && isStaff();
        allow write: if isSignedIn() && isStaff();
      }

      // Append-only provenance log for Archive/Restore — see ADR-005.
      // Deliberately lighter-weight than auditLogs (which only a Cloud
      // Function can write): Archive/Restore are both reversible, so a
      // forged entry here is low-stakes and independently checkable against
      // the document's actual recordState. The strongest guarantee
      // (auditLogs + Cloud Function) is reserved for Permanent Deletion,
      // the one irreversible operation. No update/delete granted to any
      // client — each event's own `type` determines who may create it,
      // mirroring the same authority split as the transitions above.
      match /lifecycleEvents/{eventId} {
        allow read: if isSignedIn() && isStaff();
        allow create: if isSignedIn() && (
          (isStaff() && request.resource.data.type == 'archived') ||
          (isAdmin() && request.resource.data.type == 'restored')
        );
        allow update, delete: if false;
      }
    }

    // ---- appConfig/global ----
    // Global app configuration (today: forced-update version gate; reserved
    // for maintenance mode / feature flags later — see
    // docs/ai-workflow/FORCED_UPDATE_IMPLEMENTATION_PLAN.md). Non-sensitive
    // operational metadata only — readable by anyone, including signed-out
    // users, since the sign-in screen itself must be forceable. No in-app
    // admin UI writes it in v1; edited manually via Console/Admin SDK, same
    // operating model as users/{uid}/meta/isActivated.
    match /appConfig/global {
      allow read: if true;
      allow write: if false;
    }

    // Explicit default-deny for everything else (Firestore denies by default
    // anyway; written out for clarity/auditability of this rules file).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
