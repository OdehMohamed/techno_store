// DRAFT — Phase 1 Firestore rules. NOT deployed. NOT wired into firebase.json.
// Companion to docs/ai-workflow/PHASE1_IMPLEMENTATION_PLAN.md — read that document
// for rationale, open questions, and the verification checklist before deploying.
//
// Scope: ADR-002 Phase 1 (role stored as a Firestore field, immutable from clients)
// + ADR-001 Option A (sensitive fields split into a `private/sensitive` subdocument)
// + ADR-003 (Guest is simply absent from every allow-list — no special-casing needed).
//
// Role storage: `users/{uid}.type` (int). 0=Admin, 1=Customer, 2=Reception,
// 3=Maintenance, 9=Guest (reserved, intentionally granted nothing below).

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----

    function isSignedIn() {
      return request.auth != null;
    }

    // NOTE: this performs a document read on every rule evaluation that calls it.
    // See PHASE1_IMPLEMENTATION_PLAN.md's cost note — this is the expected,
    // accepted cost of Phase 1's field-based role model (Phase 2 / ADR-002
    // removes this cost via Custom Claims).
    function callerType() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.type
        : null;
    }

    function isAdmin()       { return callerType() == 0; }
    function isCustomer()    { return callerType() == 1; }
    function isReception()   { return callerType() == 2; }
    function isMaintenance() { return callerType() == 3; }
    // Guest (9) and any unrecognized value: deliberately not given a helper.
    // Allow-list model — anything not explicitly named above gets nothing,
    // by construction, per ADR-003. Do not add isGuest()/grant it access
    // without a new ADR.

    function isStaff() {
      return isAdmin() || isReception() || isMaintenance();
    }

    // ---- users/{uid} ----

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isStaff());

      // New profile creation: only the user themselves, and only as Customer.
      // Matches the only code path that creates this document today
      // (AuthServices.completeUserProfile, called once at signup).
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.type == 1;

      // Profile updates: only the user themselves, and `type` may never change.
      // This applies even to Admins editing their own document — Phase 1
      // intentionally has NO client-side path to change any role, including
      // one's own. Role changes are Admin-SDK/Console only in Phase 1.
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.type == resource.data.type;

      allow delete: if false; // no deletion flow exists today; revisit if one is built.

      // users/{uid}/meta/isActivated
      match /meta/{metaDoc} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isStaff());
        // Confirmed by product owner (2026-07-03): this is currently changed
        // manually via the Firebase Console by a privileged operator, which
        // uses IAM-authenticated access and is NOT subject to these rules —
        // this deny-all-client-writes rule does not affect that workflow.
        // A future Admin user-management feature (see ADR-004) will need a
        // trusted server-side mechanism (Cloud Function) to write this field
        // on behalf of an in-app Admin action — never a direct client write,
        // which would reopen the same class of risk ADR-002 closes for `type`.
        allow write: if false;
      }
    }

    // ---- maintenanceDevices/{deviceId} ----

    match /maintenanceDevices/{deviceId} {
      // Staff: full unfiltered read. Customer: only their own device, AND
      // the client query must be shaped to match (e.g. a `where('userId', '==', uid)`
      // filter) — Firestore rejects list queries it can't prove are scoped to
      // this condition. The existing customer code path already filters this
      // way (MaintenanceListServices.streamMaintenanceDevices), so no query
      // shape change is expected to be needed — verify per the checklist.
      allow read: if isSignedIn() && (
        isStaff() ||
        (isCustomer() && resource.data.userId == request.auth.uid)
      );

      // Create, update, and delete are all staff-wide (Admin, Reception,
      // Maintenance), per explicit product-owner decision (2026-07-03) —
      // uniform across all three write operations. Customers and Guest are
      // denied all three regardless. (An earlier draft had narrowed create
      // to Reception-only and delete to Admin-only; both are superseded.)
      allow create: if isSignedIn() && isStaff();
      allow update: if isSignedIn() && isStaff();

      // Deletion cascades client-side (Storage images + the private/sensitive
      // subdocument below must also be deleted by the calling code — Firestore
      // does not cascade-delete subcollections automatically). See
      // PHASE1_IMPLEMENTATION_PLAN.md "Cascade deletion behavior" for the
      // required client-side sequencing, confirmation UX, and retry handling.
      allow delete: if isSignedIn() && isStaff();

      // Sensitive fields (pin, patternLock, notesHidden) — ADR-001 Option A.
      // No customer exception, ever, per explicit product-owner instruction:
      // the owning customer must never read these values.
      match /private/{doc} {
        allow read: if isSignedIn() && isStaff();
        allow write: if isSignedIn() && isStaff();
      }
    }

    // Explicit default-deny for everything else (Firestore denies by default
    // anyway; written out for clarity/auditability of this rules file).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
