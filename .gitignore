# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# Web related
lib/generated_plugin_registrant.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Migration script output — contains real production customer PII and
# plaintext sensitive fields (pin/patternLock/notesHidden) when run against
# production. Must never be committed. See scripts/migration/README.md.
scripts/migration/backups/
scripts/migration/node_modules/

# Android app signing key. Must never be committed — anyone with this file
# could sign a malicious update Android would trust as coming from this
# developer. android/key.properties (which references this file) is already
# gitignored via android/.gitignore; this was not, until now.
*.jks
*.keystore

# Build cache leakage found in android/build/ (Xcode XCBuildData ended up
# nested there — looks like a build-tooling anomaly, not intentional).
# Regenerable in all cases; never source. The top-level /build/ rule above
# only matches the repo-root build/ directory, not this nested one.
android/build/
